# ─── Copernicus Climate Data Store (CDS) API ──────────────────────────
# Register: https://cds.climate.copernicus.eu/profile
# Then create API key: https://cds.climate.copernicus.eu/api-how-to
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=your_api_key_here

# ─── DWD OpenData (free, no key needed) ──────────────────────────────
# DWD is rate-limited but does not require authentication

# ─── EU ETS Benchmarks (free AWS Open Data) ──────────────────────────
# No key required

# ─── UBA Umweltbundesamt (free) ──────────────────────────────────────
# No key required

# ─── SQLite Cache Path ───────────────────────────────────────────────
# Default: ./climate_cache.db
CLIMATE_CACHE_PATH=./climate_cache.db

# ─── Server Config ───────────────────────────────────────────────────
LOG_LEVEL=INFO
